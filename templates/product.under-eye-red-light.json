    "how_to_use": {
      "type": "step-instructions",
      "blocks": {
        "step_1": {
          "type": "step",
          "settings": {
            "image": "",
            "text": "<p><strong>Step 1: Cleanse</strong></p><p>Start with clean, dry skin around your eye area. Remove all makeup and skincare products.</p>"
          },
          "blocks": {}
        },
        "step_2": {
          "type": "step",
          "settings": {
            "image": "",
            "text": "<p><strong>Step 2: Position</strong></p><p>Place RevitalEyes gently under each eye. The curved design fits perfectly along your orbital bone.</p>"
          },
          "blocks": {}
        },
        "step_3": {
          "type": "step",
          "settings": {
            "image": "",
            "text": "<p><strong>Step 3: Activate</strong></p><p>Press the power button to begin your 10-minute therapy session. Relax and let the light work.</p>"
          },
          "blocks": {}
        },
        "step_4": {
          "type": "step",
          "settings": {
            "image": "",
            "text": "<p><strong>Step 4: Moisturize</strong></p><p>Apply your favorite eye cream immediately after. Light therapy increases product absorption by up to 40%.</p>"
          },
          "blocks": {}
        }
      },
      "block_order": ["step_1", "step_2", "step_3", "step_4"],
