    "photo_testimonials": {
      "type": "testimonials",
      "blocks": {
        "testi_1": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Thi_t_k_ch_a_co_ten_10.png",
            "star_rating": 5,
            "title": "Incredible transformation!",
            "text": "<p>\"I've struggled with dark circles my whole life. After 3 weeks of using RevitalEyes every morning, people started asking if I'd been on vacation. This device is life-changing!\"</p>",
            "author": "<strong>Sarah M.</strong> — Verified Buyer"
          }
        },
        "testi_2": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Thi_t_k_ch_a_co_ten_11.png",
            "star_rating": 5,
            "title": "My secret weapon",
            "text": "<p>\"As a nurse working night shifts, my under-eye puffiness was hard to hide and made me look exhausted. This device has been my saving grace. I use it during my morning wind-down, and the difference is truly remarkable.\"</p>",
            "author": "<strong>Jennifer K.</strong> — Verified Buyer"
          }
        },
        "testi_3": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Thi_t_k_ch_a_co_ten_9.png",
            "star_rating": 5,
            "title": "Finally works!",
            "text": "<p>\"I've tried every eye cream on the market. Nothing worked until RevitalEyes. The red light therapy actually does what it promises. My fine lines are visibly reduced after just 4 weeks.\"</p>",
            "author": "<strong>Michelle T.</strong> — Verified Buyer"
          }
        },
        "testi_4": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Thi_t_k_ch_a_co_ten_6.png",
            "star_rating": 5,
            "title": "Worth every penny",
            "text": "<p>\"I was hesitant to spend money on another beauty gadget. But after seeing my skin brighten up in just about two weeks, I wish I had tried it sooner. Even my husband noticed I look less tired lately.\"</p>",
            "author": "<strong>Amanda R.</strong> — Verified Buyer"
          }
        },
        "testi_5": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Thi_t_k_ch_a_co_ten_1.png",
            "star_rating": 5,
            "title": "Dermatologist recommended",
            "text": "<p>\"My dermatologist actually recommended red light therapy for my chronic puffiness. I chose RevitalEyes because it's FDA cleared and I couldn't be happier with the results.\"</p>",
            "author": "<strong>Christine L.</strong> — Verified Buyer"
          }
        },
        "testi_6": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Thi_t_k_ch_a_co_ten_5.png",
            "star_rating": 5,
            "title": "My morning ritual",
            "text": "<p>\"RevitalEyes has become my favorite part of my morning routine. 10 minutes while I drink coffee and I walk out the door looking 5 years younger. Simple, effective, incredible.\"</p>",
            "author": "<strong>Diana P.</strong> — Verified Buyer"
          }
        }
      },
