          "settings": {
            "post_author": "Eleanor Kensington",
            "post_author_avatar": "shopify://shop_images/Phu-Nu-Trung-Nien.jpg",
            "post_author_verified": true,
            "post_time": "1 month ago",
            "post_text": "<p>As someone who's tried every eye cream under the sun, I was hesitant to try a device. But WOW. The fine lines around my eyes have visibly reduced after just 4 weeks of daily use. My friends keep asking what I'm doing differently. This is my secret weapon! 💕</p>",
            "post_image": "shopify://shop_images/C25E2FAE-1F87-4AFE-AB03-C916972FDDDE_1_201_a.jpg",
