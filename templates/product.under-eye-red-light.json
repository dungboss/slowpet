    "reviews": {
      "type": "facebook-testimonials",
      "blocks": {
        "review_1": {
          "type": "column",
          "settings": {
            "post_author": "Charlotte Dubois",
            "post_author_avatar": "shopify://shop_images/0AC7DD7B-523F-4280-860A-E849117B4130_4_5005_c.jpg",
            "post_author_verified": true,
            "post_time": "2 weeks ago",
            "post_text": "<p>I've been using RevitalEyes for 3 weeks and the difference is incredible! My dark circles are so much lighter and the puffiness I used to wake up with is basically gone. I was skeptical at first but this thing actually works. Worth every penny! ⭐⭐⭐⭐⭐</p>",
            "post_image": "shopify://shop_images/7e7c9cf0-04f2-4f2b-8a31-a4e2bb940cdb.avif",
