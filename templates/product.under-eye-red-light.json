        "step_2": {
          "type": "step",
          "settings": {
            "image": "",
            "text": "<p><strong>Position the Device</strong></p><p>Place RevitalEyes gently under each eye. The ergonomic curved design fits perfectly along your orbital bone for maximum contact and comfort.</p>"
          },
          "blocks": {}
        },
        "step_3": {
          "type": "step",
          "settings": {
            "image": "",
            "text": "<p><strong>Activate & Relax</strong></p><p>Press the power button to begin your 10-minute therapy session. The device auto-shuts off. Simply relax and let the clinically-proven wavelengths do their work.</p>"
          },
          "blocks": {}
        },
        "step_4": {
          "type": "step",
          "settings": {
            "image": "",
            "text": "<p><strong>Apply Eye Cream</strong></p><p>Immediately after your session, apply your favorite eye cream or serum. Light therapy increases product absorption by up to 40%, amplifying results.</p>"
          },
          "blocks": {}
        },
        "step_5": {
          "type": "step",
          "settings": {
            "image": "",
            "text": "<p><strong>Repeat Daily</strong></p><p>Use RevitalEyes every morning for best results. Most customers see visible improvement in dark circles and puffiness within 10–14 days of consistent daily use.</p>"
          },
          "blocks": {}
        }
      },
