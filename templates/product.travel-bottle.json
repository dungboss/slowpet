        "column_PkLqfV": {
          "type": "column",
          "settings": {
            "post_author": "Jason Park",
            "post_author_avatar": "shopify://shop_images/5a4ad2a8-9e68-4394-910b-e2f10850e1d9_-_Copy.png",
            "post_author_verified": false,
            "post_time": "1 Day ago",
            "post_text": "<p>Just got back from a week-long hiking trip and this bottle is a lifesaver. I was so worried about my expensive shampoo leaking all over my clothes, but the double-layer design kept everything perfectly sealed. Switching between products is super smooth. Buying a second one for my girlfriend's birthday!</p>",
            "post_image": "shopify://shop_images/61YG957Ht6L.jpg",
            "post_reactions": "like, love, care",
            "post_reactions_text": "2.1k",
            "post_comments_text": "236 Comments",
            "comment_1_author": "Comment author",
            "comment_1_author_verified": false,
            "comment_1_time": "2h ago",
