    "facebook_testimonials_r6Afm8": {
      "type": "facebook-testimonials",
      "blocks": {
        "column_Y9BLnV": {
          "type": "column",
          "settings": {
            "post_author": "Sarah Mitchell",
            "post_author_avatar": "shopify://shop_images/381aaab70e9decd5fac1e9d21500eb89.webp",
            "post_author_verified": false,
            "post_time": "22h ago",
            "post_text": "<p>Honestly, a game-changer for my business trips! I used to carry a bulky toiletry bag that always got flagged at security. This 4-in-1 bottle fits everything I need and passes TSA without a single question. It's so compact that I can even fit it in my smallest carry-on. Best $19 I've spent this year!</p>",
            "post_image": "shopify://shop_images/71_Lrt1wzzL.jpg",
            "post_reactions": "like, love, care",
            "post_reactions_text": "129",
            "post_comments_text": "45 Comments",
            "comment_1_author": "Comment author",
